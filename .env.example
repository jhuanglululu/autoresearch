# Copy to .env — real tokens live here, never in models.toml.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DISCORD_BOT_TOKEN=
# Discord user id allowed to control the orchestrator (gates everything)
AUTORESEARCH_ADMIN=
# Discord channel id the bot listens/posts in (the one steering channel)
AUTORESEARCH_CHANNEL=
# OPTIONAL: a Discord FORUM channel id for a read-only live feed of subagent activity
# (one thread per session). Leave unset to disable the feed entirely.
AUTORESEARCH_FORUM=
